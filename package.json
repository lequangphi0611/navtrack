    "clsx": "^2.1.1",
    "decimal.js": "^10.6.0",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.31",
    "pino": "^10.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.2",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "xirr": "^1.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
