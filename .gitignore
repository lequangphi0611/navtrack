# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.test

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# testing (e2e)
/playwright-report/
/test-results/
/blob-report/

# Playwright MCP: ảnh soi UI component (design-implementer) — chỉ là artifact
# tạm để main context gửi cho user, không cần persist qua git.
/.playwright-mcp/

# job Python
jobs/*/.venv/
jobs/*/__pycache__/
jobs/*/*.egg-info/

# scratch notes (không commit)
/tmp/

# design-implementer: cache raw mockup HTML đã fetch từ Claude Design — chỉ
# để tránh fetch trùng trong máy hiện tại, không cần persist qua git (mất là
# fetch lại được). index.json bên cạnh (mapping component -> design file) vẫn
# commit bình thường.
/.claude/design-cache/raw/
