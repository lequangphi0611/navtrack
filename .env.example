# Local dev: docker compose up -d (xem README.md)
DATABASE_URL="postgresql://navtrack:navtrack@localhost:5433/navtrack?schema=public"

# Auth.js + Google OAuth — required, Auth.js v5 throws at runtime if unset
AUTH_SECRET=       # openssl rand -base64 32
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Required before `pnpm db:seed` — seeded as the first AllowedUser (canInvite = true)
SEED_ADMIN_EMAIL=

LOG_LEVEL="info"
